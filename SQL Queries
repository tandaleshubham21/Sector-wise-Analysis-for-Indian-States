-- Question 1
SELECT *
FROM sector_analysis
WHERE State_Name = 'Chhattisgarh';

-- Question 2
SELECT Dist_Name,
       State_Name,
       Year,
       Total_Current_Prices
FROM sector_analysis
WHERE Total_Current_Prices > 100000
AND Year = 2020;

-- Question 3
SELECT Year,
       SUM(Primary_Sector_Current_Prices)
       AS Total_Primary_Contribution
FROM sector_analysis
GROUP BY Year;

-- Question 4
SELECT State_Code,
       State_Name,
       Dist_Name
FROM sector_analysis;

-- Question 5
SELECT Dist_Name,
       Year,
       Secondary_Sector_Current_Prices,
       LAG(Secondary_Sector_Current_Prices)
       OVER(PARTITION BY Dist_Name ORDER BY Year)
       AS Previous_Year
FROM sector_analysis;

-- Question 6
SELECT Dist_Name,
       MAX(Tertiary_Sector_Current_Prices)
       AS Highest_Growth
FROM sector_analysis
GROUP BY Dist_Name
ORDER BY Highest_Growth DESC;

-- Question 7
SELECT State_Name,
       SUM(Secondary_Sector_Constant_Prices)
       AS Total_Secondary
FROM sector_analysis
GROUP BY State_Name;

-- Question 8
SELECT Dist_Name,
       Per_Capita_Current_Prices
FROM sector_analysis
WHERE Dist_Name IN ('Pune', 'Mumbai');

-- Question 9
SELECT Dist_Name,
       State_Name,
       Total_Constant_Prices,
       RANK() OVER(
       PARTITION BY State_Name
       ORDER BY Total_Constant_Prices DESC)
       AS District_Rank
FROM sector_analysis;

-- Question 10
SELECT Dist_Name,
       State_Name
FROM sector_analysis
WHERE Primary_Sector_Constant_Shares > 20;

-- Question 11
SELECT State_Name,
       AVG(Tertiary_Sector_Current_Shares)
       AS Avg_Tertiary_Share
FROM sector_analysis
GROUP BY State_Name;

-- Question 12
SELECT Dist_Name,
       Total_Current_Prices
FROM sector_analysis
ORDER BY Total_Current_Prices DESC
LIMIT 1;

-- Question 13
SELECT Dist_Name,
       (Secondary_Sector_Current_Prices /
       Total_Current_Prices) * 100
       AS Secondary_Percentage
FROM sector_analysis;

-- Question 14
SELECT Dist_Name
FROM sector_analysis
WHERE Tertiary_Sector_Constant_Shares >
      Secondary_Sector_Constant_Shares;

-- Question 15
SELECT Dist_Name
FROM sector_analysis
WHERE Primary_Sector_Current_Shares > 30
AND Secondary_Sector_Current_Shares > 30;

-- Question 16
SELECT Year,
       Total_Current_Prices
FROM sector_analysis
WHERE Dist_Name = 'Pune';

-- Question 17
SELECT State_Name,
       SUM(Tertiary_Sector_Current_Prices)
       AS Total_Tertiary
FROM sector_analysis
GROUP BY State_Name
ORDER BY Total_Tertiary DESC
LIMIT 1;

-- Question 18
SELECT DISTINCT State_Name
FROM sector_analysis;

-- Question 19
SELECT State_Name,
       SUM(Total_Current_Prices)
       AS Total_Contribution
FROM sector_analysis
GROUP BY State_Name;

-- Question 20
SELECT Dist_Name,
       Year,
       SUM(Primary_Sector_Constant_Prices)
       OVER(PARTITION BY Dist_Name ORDER BY Year)
       AS Cumulative_Total
FROM sector_analysis;
